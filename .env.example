# Database configuration
DB_URL=jdbc:mysql://localhost:3307/api_ai_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh
DB_USERNAME=root
DB_PASSWORD=your_database_password_here

# Mail/SMTP settings (Gmail app password or similar)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail_username_here@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here

# Google OAuth2 client settings
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT authentication settings
JWT_SECRET=change-this-development-secret-key-must-be-at-least-32-bytes

# Gemini AI API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# SePay Webhook configurations
SEPAY_API_KEY=sepay_mock_key
SEPAY_BANK_ID=vietcombank
SEPAY_ACCOUNT_NUMBER=1234567890
SEPAY_ACCOUNT_NAME=CONG TY APIDMP

# CORS and frontend integration URLs
ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_OAUTH_SUCCESS_URL=http://localhost:5173/oauth-success
FRONTEND_RESET_PASSWORD_URL=http://localhost:5173/reset-password
